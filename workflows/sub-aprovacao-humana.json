    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "m1",
              "name": "texto_central",
              "value": "=🔗 https://chatwoot.example.com/app/accounts/{{ $json.cliente_account_id }}/conversations/{{ $json.cliente_conversation_id }}\n\n🙋 *Pergunta do cliente:* {{ $json.pergunta_cliente }}\n\n💬 *Resposta IA:*\n{{ $json.resposta_sugerida }}\n\n📋 Use o painel *Aprovações IA* na barra lateral para aprovar ou reprovar.",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "402f7a9a-cf79-40cc-9048-fd178b3d7c02",
      "name": "monta texto",
