        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "operation": "set",
        "key": "=approval:{{ $json.id }}",
        "value": "={{ JSON.stringify({ cliente_account_id: $('ctx').item.json.cliente_account_id, cliente_conversation_id: $('ctx').item.json.cliente_conversation_id, resposta_sugerida: $('ctx').item.json.resposta_sugerida, motivo_acao: $('ctx').item.json.motivo_acao, contact_name: $('ctx').item.json.contact_name, pergunta_cliente: $('ctx').item.json.pergunta_cliente, central_message_id: $json.id, created_at: $now.toISO() }) }}",
        "expire": true,
        "ttl": 1800
      },
      "id": "8f1ae630-6bba-47ff-b8e9-21ee11859a02",
