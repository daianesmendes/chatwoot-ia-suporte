        "assignments": {
          "assignments": [
            {
              "id": "i1",
              "name": "cliente_account_id",
              "value": "={{ $json.account_id }}",
              "type": "number"
            },
            {
              "id": "i2",
              "name": "cliente_conversation_id",
              "value": "={{ $json.conversation_id }}",
              "type": "string"
            },
            {
              "id": "i3",
              "name": "resposta_sugerida",
              "value": "={{ $json.resposta_sugerida }}",
              "type": "string"
            },
            {
