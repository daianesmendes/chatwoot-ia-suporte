      "parameters": {
        "jsCode": "const redisRaw = $input.first().json.propertyName ?? $input.first().json.value ?? $input.first().json;\nconst pending = typeof redisRaw === 'string' ? JSON.parse(redisRaw) : redisRaw;\n// Recupera decision do contexto anterior (vem dos sets)\nlet decision = null;\ntry { decision = $('set decision=approve').first().json.decision; } catch(e) {}\nif (!decision) { try { decision = $('set decision=reject').first().json.decision; } catch(e) {} }\nreturn [{ json: { ...pending, decision } }];"
      },
