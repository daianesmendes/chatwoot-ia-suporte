        "assignments": {
          "assignments": [
            {
              "id": "h1",
              "name": "html",
              "value": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Aprovações IA</title>\n<style>\n* { box-sizing: border-box; }\nbody { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #1f2937; color: #f3f4f6; padding: 12px; margin: 0; }\n.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }\n.header h1 { font-size: 15px; margin: 0; }\n.btn-refresh { background: #374151; color: #fff; border: 0; padding: 6px 10px; border-radius: 6px; cursor: pointer; font-size: 12px; }\n.btn-refresh:hover { background: #4b5563; }\n.empty { text-align: center; padding: 40px 12px; color: #9ca3af; font-size: 13px; line-height: 1.6; }\n.empty a { color: #60a5fa; text-decoration: none; }\n.card { background: #374151; border-radius: 8px; padding: 12px; margin-bottom: 10px; font-size: 13px; }\n.card-header { display: flex; justify-content: space-between; font-size: 11px; color: #9ca3af; margin-bottom: 6px; }\n.card a { color: #60a5fa; text-decoration: none; font-size: 11px; }\n.card-question { color: #d1d5db; font-style: italic; margin: 6px 0; font-size: 12px; }\n.card-answer { background: #1f2937; padding: 8px; border-radius: 6px; margin: 6px 0; white-space: pre-wrap; font-size: 12px; line-height: 1.4; }\n.card-actions { display: flex; gap: 8px; margin-top: 8px; }\n.btn-approve, .btn-reject { flex: 1; padding: 8px; border-radius: 6px; border: 0; cursor: pointer; font-weight: 600; font-size: 12px; }\n.btn-approve { background: #10b981; color: #fff; }\n.btn-approve:hover { background: #059669; }\n.btn-reject { background: #ef4444; color: #fff; }\n.btn-reject:hover { background: #dc2626; }\n.btn-approve:disabled, .btn-reject:disabled { opacity: 0.5; cursor: not-allowed; }\n.status-msg { padding: 8px; border-radius: 6px; margin: 8px 0; font-size: 12px; text-align: center; }\n.status-ok { background: #065f46; }\n.status-err { background: #7f1d1d; }\n.hidden { display: none; }\n</style>\n</head>\n<body>\n<div id=\"app\" class=\"hidden\">\n  <div class=\"header\"><h1>📋 Aprovações IA</h1><button class=\"btn-refresh\" onclick=\"load()\">🔄</button></div>\n  <div id=\"status\"></div>\n  <div id=\"list\"><div class=\"empty\">Carregando...</div></div>\n</div>\n<div id=\"gate\"><div class=\"empty\">Aguardando contexto do Chatwoot...</div></div>\n<script>\nconst CENTRAL_CONV_ID = 300;\nconst BASE = 'https://n8n.example.com/webhook';\nconst CHATWOOT = 'https://chatwoot.example.com';\nconst $list = document.getElementById('list');\nconst $status = document.getElementById('status');\nconst $app = document.getElementById('app');\nconst $gate = document.getElementById('gate');\n\nlet pollTimer = null;\nlet currentConvId = null;\n\nfunction showGate(html) {\n  $app.classList.add('hidden');\n  $gate.classList.remove('hidden');\n  $gate.innerHTML = '<div class=\"empty\">' + html + '</div>';\n  if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }\n}\n\nfunction showApp() {\n  $gate.classList.add('hidden');\n  $app.classList.remove('hidden');\n  load();\n  if (!pollTimer) pollTimer = setInterval(load, 10000);\n}\n\nfunction checkAccess() {\n  if (Number(currentConvId) === CENTRAL_CONV_ID) {\n    showApp();\n  } else {\n    showGate('📌 Este painel só funciona na conversa central de Aprovações IA.<br><br><a href=\"' + CHATWOOT + '/app/accounts/1/conversations/' + CENTRAL_CONV_ID + '\" target=\"_top\">Abrir conversa central →</a>');\n  }\n}\n\nwindow.addEventListener('message', function(e) {\n  try {\n    var data = typeof e.data === 'string' ? JSON.parse(e.data) : e.data;\n    if (data && data.event === 'appContext' && data.data && data.data.conversation) {\n      currentConvId = data.data.conversation.id;\n      checkAccess();\n    }\n  } catch (err) {}\n});\n\nsetTimeout(function() {\n  if (currentConvId === null) {\n    showGate('⚠️ Não foi possível detectar o contexto do Chatwoot.<br>Abra este painel pela sidebar de uma conversa.');\n  }\n}, 5000);\n\nfunction setStatus(msg, ok) {\n  $status.innerHTML = '<div class=\"status-msg ' + (ok!==false?'status-ok':'status-err') + '\">' + msg + '</div>';\n  setTimeout(function(){$status.innerHTML='';}, 2500);\n}\nfunction timeAgo(iso) {\n  if (!iso) return '';\n  var diff = (Date.now() - new Date(iso).getTime()) / 1000;\n  if (diff < 60) return 'há instantes';\n  if (diff < 3600) return 'há ' + Math.floor(diff/60) + ' min';\n  return 'há ' + Math.floor(diff/3600) + 'h';\n}\nfunction esc(s) {\n  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');\n}\nasync function load() {\n  try {\n    var res = await fetch(BASE + '/pendentes', { cache: 'no-store' });\n    var data = await res.json();\n    var items = Array.isArray(data) ? data : (data.pendentes || []);\n    items.sort(function(a,b){ return new Date(a.created_at) - new Date(b.created_at); });\n    if (!items.length) {\n      $list.innerHTML = '<div class=\"empty\">Nenhuma sugestão pendente 🎉</div>';\n      return;\n    }\n    $list.innerHTML = items.map(function(it){\n      return '<div class=\"card\" data-id=\"' + it.central_message_id + '\">'\n        + '<div class=\"card-header\"><span><a href=\"' + CHATWOOT + '/app/accounts/' + (it.cliente_account_id||1) + '/conversations/' + it.cliente_conversation_id + '\" target=\"_top\">abrir conversa #' + it.cliente_conversation_id + ' →</a></span><span>' + timeAgo(it.created_at) + '</span></div>'\n        + (it.pergunta_cliente ? '<div class=\"card-question\">🙋 ' + esc(it.pergunta_cliente) + '</div>' : '')\n        + '<div class=\"card-answer\">💬 ' + esc(it.resposta_sugerida) + '</div>'\n        + '<div class=\"card-actions\">'\n        + '<button class=\"btn-approve\" onclick=\"act(\\'aprovar\\',\\'' + it.central_message_id + '\\',this)\">✅ Aprovar</button>'\n        + '<button class=\"btn-reject\" onclick=\"act(\\'reprovar\\',\\'' + it.central_message_id + '\\',this)\">❌ Reprovar</button>'\n        + '</div></div>';\n    }).join('');\n  } catch (e) { setStatus('Erro: ' + e.message, false); }\n}\nasync function act(action, id, btn) {\n  var card = btn.closest('.card');\n  card.querySelectorAll('button').forEach(function(b){ b.disabled = true; });\n  try {\n    await fetch(BASE + '/' + action + '?id=' + encodeURIComponent(id));\n    setStatus(action === 'aprovar' ? '✅ Aprovado' : '❌ Reprovado');\n    card.remove();\n    if (!document.querySelectorAll('.card').length) {\n      $list.innerHTML = '<div class=\"empty\">Nenhuma sugestão pendente 🎉</div>';\n    }\n  } catch (e) {\n    setStatus('Erro: ' + e.message, false);\n    card.querySelectorAll('button').forEach(function(b){ b.disabled = false; });\n  }\n}\n</script>\n</body>\n</html>",
