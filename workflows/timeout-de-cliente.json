    {
      "parameters": {
        "operation": "executeQuery",
        "query": "MERGE dbo.chatwoot_auto_close AS t\nUSING (\n  SELECT\n    TRY_CONVERT(INT,   '{{ $json.account_id }}')        AS account_id,\n    TRY_CONVERT(INT,   '{{ $json.conversation_id }}')   AS conversation_id,\n    TRY_CONVERT(INT,   '{{ $json.outgoing_message_id }}') AS outgoing_message_id,\n    TRY_CONVERT(BIGINT,'{{ $json.outgoing_created_at }}') AS outgoing_created_at\n) AS s\nON (t.account_id = s.account_id AND t.conversation_id = s.conversation_id)\n\nWHEN MATCHED THEN\n  UPDATE SET\n    t.outgoing_message_id = s.outgoing_message_id,\n    t.outgoing_created_at = s.outgoing_created_at,\n    t.updated_at = SYSDATETIME()\n\nWHEN NOT MATCHED THEN\n  INSERT (account_id, conversation_id, outgoing_message_id, outgoing_created_at, updated_at)\n  VALUES (s.account_id, s.conversation_id, s.outgoing_message_id, s.outgoing_created_at, SYSDATETIME());\n",
        "options": {}
      },
