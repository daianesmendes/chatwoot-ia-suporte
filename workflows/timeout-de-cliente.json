    {
      "parameters": {
        "jsCode": "// Chatwoot pode retornar array direto ou { payload: [...] }\nconst data = $json.payload ?? $json ?? [];\n\n// timestamp do outgoing salvo no SQL\nconst outgoingCreatedAt = Number($node[\"busca temporizador atual\"].json.outgoing_created_at); \n// ⚠️ Troque \"Microsoft SQL1\" pelo NOME do seu node SELECT (o da imagem)\n\nconst hasIncomingAfter = data.some(m =>\n  m.message_type === 0 && Number(m.created_at) > outgoingCreatedAt\n);\n\nreturn [{\n  should_close: !hasIncomingAfter,\n  hasIncomingAfter,\n  outgoingCreatedAt\n}];\n"
      },
